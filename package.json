{
  "name": "novelforge-app",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "python scripts/dev.py",
    "dev:engine": "python scripts/dev.py",
    "dev:desktop": "python scripts/dev.py",
    "install:engine": "cd apps/engine && python -m venv .venv && ./.venv/Scripts/pip install -r requirements.txt",
    "build": "npm run build -w apps/desktop",
    "setup": "npm install && cd apps/engine && uv sync",
    "start": "npm run dev",
    "win": "scripts\\win-dev.bat",
    "test": "cd apps/engine && python -m pytest -q --ignore=tests/test_agent_websocket.py --ignore=tests/test_ai_ws.py --ignore=tests/test_agent_integration.py",
    "test:frontend": "cd apps/desktop && npx vitest run",
    "update": "cmd /c scripts\\update.bat",
    "lint": "cd apps/engine && python -m ruff check . --select=E,F,I,N,W,UP --ignore=E501",
    "lint:fix": "cd apps/engine && python -m ruff check . --select=E,F,I,N,W,UP --ignore=E501 --fix && python -m ruff format ."
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "cross-env": "^10.1.0",
    "lucide-react": "^0.468.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "ws": "^8.21.0",
    "zustand": "^5.0.14"
  }
}
