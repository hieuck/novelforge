{
  "name": "@novelforge/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Offline-first AI writing studio",
  "author": "Lê Trung Hiếu <hieuck@users.noreply.github.com>",
  "type": "commonjs",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "pack": "npm run build && node scripts/build-electron.cjs && electron-builder --dir",
    "preview": "vite preview",
    "electron:dev": "node scripts/build-electron.cjs && concurrently \"vite\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "electron:build": "npm run build && node scripts/build-electron.cjs && electron-builder",
    "setup": "npm install",
    "lint": "eslint src --ext ts,tsx",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.novelforge.app",
    "productName": "NovelForge",
    "copyright": "Copyright 2025 NovelForge",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "electron/**/*.cjs",
      "scripts/**"
    ],
    "asarUnpack": [
      "scripts/**"
    ],
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "NovelForge"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@novelforge/shared": "^0.1.0",
    "i18next": "^26.3.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^6.28.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/ui": "^4.1.8",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "playwright": "^1.60.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "~6.0.3",
    "vite": "^5.4.14",
    "vitest": "^4.1.8",
    "wait-on": "^7.2.0"
  }
}
