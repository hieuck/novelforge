# NovelForge Environment Configuration
# Copy this file to .env and adjust values for your setup.

# Engine settings
ENGINE_HOST=127.0.0.1
ENGINE_PORT=9000

# Git remote for self-updater
NOVELFORGE_REMOTE=https://github.com/hieuck/novelforge.git
NOVELFORGE_BRANCH=main

# Default AI provider (ollama, openai, comfyui)
AI_PROVIDER=ollama
AI_BASE_URL=http://localhost:11434
AI_MODEL=gemma3:4b
AI_API_KEY=
